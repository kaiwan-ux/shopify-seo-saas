# Application
APP_NAME="Shopify SEO SaaS"
APP_VERSION="0.1.0"
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# Database
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=seo_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=seo_db
DATABASE_URL=postgresql+asyncpg://seo_user:change_me_in_production@db:5432/seo_db

# Security — generate with: openssl rand -hex 32
JWT_SECRET_KEY=change_me_use_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=INFO
LOG_JSON=false

# Application URL
APP_URL=http://localhost:8000

# Token encryption — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=change_me_generate_fernet_key

# Shopify Partner App
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_SCOPES=read_products,write_products,read_content,write_content,read_online_store_pages,read_redirects,write_redirects,read_inventory
SHOPIFY_API_VERSION=2025-01
SHOPIFY_OAUTH_STATE_EXPIRE_MINUTES=10

# MCP Server (optional — configure when MCP server is deployed)
MCP_SERVER_URL=
MCP_SERVER_COMMAND=
MCP_BEARER_TOKEN=
MCP_TRANSPORT=streamable-http
MCP_REQUEST_TIMEOUT_SECONDS=60
MCP_MAX_RETRIES=3

# Scheduled sync
SYNC_ENABLED=true
SYNC_INTERVAL_HOURS=6
SYNC_BATCH_SIZE=50

# --- Phase 3: AI Infrastructure ---

# LLM Provider (openai | anthropic | gemini | ollama)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096
LLM_TIMEOUT_SECONDS=120

# LLM API Keys
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=your_primary_groq_api_key
GROQ_API_KEY_FALLBACK=your_fallback_groq_api_key
OLLAMA_BASE_URL=http://localhost:11434

# Embeddings (openai | nomic | bge)
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Qdrant Vector Database
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION_PREFIX=seo

# RAG
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_TOP_K=5

# AI Workflow
AI_MAX_RETRIES=3
AI_TOOL_TIMEOUT_SECONDS=60
AI_REQUIRE_APPROVAL_FOR_WRITES=true

# LangSmith (optional)
LANGSMITH_ENABLED=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=shopify-seo-saas

# OpenTelemetry (optional)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=shopify-seo-saas
